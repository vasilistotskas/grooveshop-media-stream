{
  "name": "grooveshop-media-stream",
  "version": "2.56.1",
  "type": "module",
  "description": "Grooveshop Media Stream",
  "repository": {
    "type": "git",
    "url": "https://github.com/vasilistotskas/grooveshop-media-stream.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vasilistotskas/grooveshop-media-stream/issues"
  },
  "homepage": "https://github.com/vasilistotskas/grooveshop-media-stream#readme",
  "files": [
    "build/dist/**/*"
  ],
  "imports": {
    "#microservice/*": {
      "types": "./src/MediaStream/*.ts",
      "default": "./build/dist/MediaStream/*.js"
    },
    "#storage/*": "./var/*"
  },
  "scripts": {
    "prebuild": "rimraf build/dist && node scripts/inject-version.cjs",
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --tsc --watch",
    "dev:all": "ncu -u && pnpm i && pnpm run build && pnpm run lint && pnpm run dev",
    "debug": "nest start --debug --watch",
    "prod": "node build/dist/main",
    "repl": "nest start --watch --entryFile repl",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --config src/test/vitest.e2e.ts",
    "test:coverage": "vitest run --coverage",
    "cache:clear": "node scripts/clear-cache.cjs",
    "semantic-release": "semantic-release",
    "trivy-scan": "trivy fs . --severity HIGH,CRITICAL --skip-dirs node_modules,dist,build --exit-code 1"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/bull": "11.0.4",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/serve-static": "5.0.5",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "axios": "1.18.1",
    "bull": "4.16.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "compression": "1.8.1",
    "cron": "4.4.0",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "isomorphic-dompurify": "^3.18.0",
    "node-cache": "5.1.2",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.43",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/node": "26.0.1",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "1.6.20",
    "eslint": "10.6.0",
    "semantic-release": "25.0.5",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.9"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "build/dist",
              "label": "Distribution"
            }
          ]
        }
      ]
    ]
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.12.0"
  }
}
