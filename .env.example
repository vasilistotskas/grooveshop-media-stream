# Docker Configuration
COMPOSE_PROJECT_NAME=grooveshop-media-stream
LAUNCH_AS=HYBRID

# Server Configuration
NODE_ENV=development
PORT=3003
HOST=0.0.0.0

# CORS Configuration
# In production CORS_ORIGIN MUST be set explicitly (startup fails otherwise).
CORS_ORIGIN=*
CORS_METHODS=GET
CORS_MAX_AGE=86400

# Memory Cache Configuration
CACHE_MEMORY_MAX_SIZE=104857600
CACHE_MEMORY_DEFAULT_TTL=3600
CACHE_MEMORY_CHECK_PERIOD=600
CACHE_MEMORY_MAX_KEYS=1000
CACHE_MEMORY_WARNING_THRESHOLD=80

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=7200
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100
# TTL (ms) for memoising the Redis health probe result
REDIS_HEALTH_CACHE_TTL=10000

# File Cache Configuration
CACHE_FILE_DIRECTORY=./storage

# Cache Warming Configuration
CACHE_WARMING_ENABLED=true
CACHE_WARMING_ON_START=true
CACHE_WARMING_MAX_FILES=50
CACHE_WARMING_CRON=0 */6 * * *
CACHE_WARMING_THRESHOLD=5
# Base TTL (seconds) for warmed entries; access count scales it up
CACHE_WARMING_BASE_TTL=3600

# Popular-key preloading (multi-layer cache)
CACHE_PRELOADING_ENABLED=false
CACHE_PRELOADING_INTERVAL=300000

# Image Cache TTLs (seconds)
CACHE_IMAGE_PUBLIC_TTL=31104000
CACHE_IMAGE_PRIVATE_TTL=15552000
# Negative-cache TTL — suppresses retries for failed upstream fetches
CACHE_IMAGE_NEGATIVE_TTL=300

# Processing Configuration
# Container CPU limit used to derive Sharp concurrency (fractions allowed)
PROCESSING_CPU_CORES=1.5

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_SYSTEM_METRICS_INTERVAL=60000
MONITORING_PERFORMANCE_METRICS_INTERVAL=30000

# Image Source URLs
BACKEND_URL=http://localhost:8000

# External Services Configuration
EXTERNAL_REQUEST_TIMEOUT=30000

# HTTP Client Configuration
HTTP_TIMEOUT=30000
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY=1000
HTTP_MAX_RETRY_DELAY=10000
HTTP_POOL_MAX_SOCKETS=50
HTTP_POOL_KEEP_ALIVE_MS=1000
HTTP_CIRCUIT_BREAKER_ENABLED=true
HTTP_CIRCUIT_BREAKER_FAILURE_THRESHOLD=50
HTTP_CIRCUIT_BREAKER_RESET_TIMEOUT=30000
HTTP_CIRCUIT_BREAKER_MONITORING_PERIOD=60000
HTTP_CIRCUIT_BREAKER_MINIMUM_REQUESTS=10
# Comma-separated upstream URLs probed by the HTTP health indicator (empty disables probing)
HTTP_HEALTH_CHECK_URLS=
HTTP_HEALTH_CHECK_TIMEOUT=5000

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT_MAX=500
RATE_LIMIT_IMAGE_PROCESSING_WINDOW_MS=60000
RATE_LIMIT_IMAGE_PROCESSING_MAX=300
RATE_LIMIT_HEALTH_CHECK_WINDOW_MS=10000
RATE_LIMIT_HEALTH_CHECK_MAX=1000
RATE_LIMIT_BYPASS_HEALTH_CHECKS=true
RATE_LIMIT_BYPASS_METRICS_ENDPOINT=true
RATE_LIMIT_BYPASS_STATIC_ASSETS=true
RATE_LIMIT_BYPASS_WHITELISTED_DOMAINS=example.com,*.example.com
RATE_LIMIT_BYPASS_BOTS=true

# Input Validation Configuration
# Comma-separated hostnames allowed as upstream image sources (defaults cover local + webside.gr)
VALIDATION_ALLOWED_DOMAINS=
VALIDATION_MAX_STRING_LENGTH=10000

# Storage Monitoring Thresholds
STORAGE_MAX_SIZE=1073741824
STORAGE_MAX_FILE_AGE_DAYS=30
STORAGE_WARNING_SIZE=838860800
STORAGE_CRITICAL_SIZE=1073741824
STORAGE_WARNING_FILE_COUNT=5000
STORAGE_CRITICAL_FILE_COUNT=10000

# Storage Cleanup (daily retention-policy cron)
STORAGE_CLEANUP_ENABLED=true
STORAGE_CLEANUP_CRON=0 2 * * *
STORAGE_CLEANUP_DRY_RUN=false
STORAGE_CLEANUP_MAX_DURATION=300000

# Storage Eviction (lru | lfu | size-based | age-based | intelligent)
STORAGE_EVICTION_STRATEGY=intelligent
# conservative | moderate | aggressive
STORAGE_EVICTION_AGGRESSIVENESS=moderate
STORAGE_EVICTION_PRESERVE_POPULAR=true
STORAGE_EVICTION_MIN_ACCESS_COUNT=5
STORAGE_EVICTION_MAX_FILE_AGE_DAYS=7

# Storage Optimization (compression / deduplication, every 6 hours)
STORAGE_OPTIMIZATION_ENABLED=true
STORAGE_OPTIMIZATION_STRATEGIES=deduplication
STORAGE_OPTIMIZATION_POPULAR_THRESHOLD=10
STORAGE_OPTIMIZATION_COMPRESSION_LEVEL=6
STORAGE_OPTIMIZATION_CREATE_BACKUPS=false
STORAGE_OPTIMIZATION_MAX_TIME=600000

# Graceful Shutdown
SHUTDOWN_TIMEOUT=30000
SHUTDOWN_FORCE_TIMEOUT=60000

# Internal admin secret — required to call /metrics and POST /health/circuit-breaker/reset.
# Leave unset in development (endpoints will return 401). Set a strong random value in production.
INTERNAL_ADMIN_SECRET=
